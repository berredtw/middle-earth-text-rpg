@echo off
chcp 65001 >nul
title 查詢連線位址
echo ═══════════════════════════════════════════════
echo   下面列出的「IPv4」就是你這台電腦的位址。
echo.
echo   同一個 Wi-Fi 的朋友，請在遊戲「連線」分頁填：
echo       ws://IPv4位址:2941
echo   （例如 ws://192.168.1.50:2941），密語相同即可進入。
echo ═══════════════════════════════════════════════
echo.
ipconfig | findstr /i "IPv4"
echo.
echo ═══════════════════════════════════════════════
pause
